# Скопируйте в .env и заполните. Секреты не коммитьте.
#
# Учебный FA: задеплойте contracts/FAToken.sol в Sepolia (см. README),
# затем укажите Sepolia RPC и адрес контракта.

TELEGRAM_BOT_TOKEN=123456:replace_with_real_bot_token
JWT_SECRET=replace_with_strong_random_secret
JWT_EXP_MINUTES=720
WEB3_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
FA_TOKEN_CONTRACT=0x0000000000000000000000000000000000000000
FA_TOKEN_DECIMALS=18
FA_TOKEN_SYMBOL=FA
ADMIN_TELEGRAM_IDS=123456789
